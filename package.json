{
  "name": "ats-resume-analyzer",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:ui": "vite",
    "dev": "node scripts/start-dev.js",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test:api": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand --verbose --detectOpenHandles",
    "test:api:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --runInBand",
    "test:e2e": "bddgen && playwright test",
    "test:e2e:ui": "bddgen && playwright test --ui",
    "test:e2e:headed": "bddgen && playwright test --headed"
  },
  "dependencies": {
    "cookie": "^1.1.1",
    "framer-motion": "^12.38.0",
    "js-cookie": "^3.0.8",
    "lucide-react": "^0.344.0",
    "mongodb": "^7.2.0",
    "pdfjs-dist": "^4.7.76",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/cookie": "^0.6.0",
    "@types/jest": "^30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vercel/node": "^3.2.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.2.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-cucumber": "^4.5.0",
    "lint-staged": "^17.0.7",
    "mongodb-memory-server": "^11.2.0",
    "playwright-bdd": "^9.0.0",
    "postcss": "^8.4.47",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.13",
    "ts-jest": "^29.4.11",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.60.1",
    "vercel": "^54.9.1",
    "vite": "^5.4.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": [
      "prettier --write"
    ]
  }
}
